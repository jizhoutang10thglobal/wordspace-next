{
  "spec": "f46-theme-demo",
  "title": "暗 / 亮主题切换的可见验收",
  "note": "由人(Colin)拍板、实现 AI 不许改（见 .github/CODEOWNERS）。可见性口径：Colin 定为『状态栏变色就算数，文档纸面绝对不变』。阈值留宽余量防 xvfb/mac 色差 flaky。",
  "launch": {
    "main": "src/main.js",
    "waitFor": "#doc-container h1, #doc-container p"
  },
  "steps": [
    { "snapshot": "light" },
    { "click": "#theme-toggle" },
    { "snapshot": "dark" },
    { "click": "#theme-toggle" },
    { "snapshot": "lightAgain" }
  ],
  "checks": [
    {
      "id": "status-bar-darkens",
      "desc": "点开关后状态栏背景从浅变深——这是用户真能看见的那个变化",
      "selector": "#status-bar",
      "metric": "bgLuminance",
      "states": { "light": { "min": 0.5 }, "dark": { "max": 0.15 } },
      "relations": ["dark < light"]
    },
    {
      "id": "doc-stays-white",
      "desc": "文档纸面两态恒白、不被主题染色",
      "selector": "#doc-container",
      "metric": "bgColor",
      "states": {
        "light": { "equals": "rgb(255, 255, 255)" },
        "dark": { "equals": "rgb(255, 255, 255)" }
      },
      "invariantAcross": ["light", "dark"]
    },
    {
      "id": "shell-darkens",
      "desc": "外壳整体(body)暗态变暗——外壳主题逻辑对(屏幕上被白文档盖住，但 computed 仍可读)",
      "selector": "body",
      "metric": "bgLuminance",
      "states": { "light": { "min": 0.5 }, "dark": { "max": 0.15 } },
      "relations": ["dark < light"]
    },
    {
      "id": "toggle-reversible",
      "desc": "再点一次回到亮态(状态栏亮度回升)",
      "selector": "#status-bar",
      "metric": "bgLuminance",
      "states": { "lightAgain": { "min": 0.5 } }
    }
  ]
}
