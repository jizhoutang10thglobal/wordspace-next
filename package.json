{
  "name": "wordspace-next",
  "version": "0.0.0",
  "private": true,
  "description": "Wordspace Next — HTML-native document editor (official repo). Spec-driven development with an adversarial acceptance pipeline; ships signed/notarized macOS builds with auto-update.",
  "license": "UNLICENSED",
  "author": "Wordspace Next",
  "main": "src/main.js",
  "scripts": {
    "start": "electron .",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "dist": "electron-builder --mac"
  },
  "dependencies": {
    "electron-updater": "^6.8.3"
  },
  "devDependencies": {
    "@playwright/test": "^1.49.0",
    "electron": "^33.0.0",
    "electron-builder": "^26.8.1",
    "vitest": "^2.1.0"
  },
  "build": {
    "appId": "com.tenthglobal.wordspace-next",
    "productName": "Wordspace Next",
    "directories": {
      "output": "release"
    },
    "files": [
      "src/**",
      "package.json"
    ],
    "publish": {
      "provider": "github",
      "owner": "jizhoutang10thglobal",
      "repo": "wordspace-next"
    },
    "mac": {
      "target": [
        "dmg",
        "zip"
      ],
      "category": "public.app-category.productivity",
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "entitlements": "build-resources/entitlements.mac.plist",
      "entitlementsInherit": "build-resources/entitlements.mac.plist",
      "notarize": true,
      "artifactName": "wordspace-next-${version}-${arch}.${ext}"
    },
    "dmg": {
      "title": "Wordspace Next",
      "sign": true
    },
    "afterAllArtifactBuild": "scripts/notarize-dmg.js"
  }
}
