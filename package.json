{
  "name": "wordspace-next",
  "version": "0.1.0",
  "private": true,
  "description": "Wordspace Next — local in-place HTML document editor (Notion-like). Signed/notarized macOS builds with auto-update.",
  "license": "UNLICENSED",
  "author": "Wordspace Next",
  "main": "src/main/main.js",
  "scripts": {
    "start": "electron .",
    "test": "node --test test/*.test.js",
    "test:e2e": "playwright test",
    "dist": "electron-builder --mac"
  },
  "dependencies": {
    "electron-updater": "^6.8.3"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "electron": "^42.0.0",
    "electron-builder": "^26.8.1",
    "jsdom": "^29.1.1"
  },
  "build": {
    "appId": "com.tenthglobal.wordspace-next",
    "productName": "Wordspace Next",
    "directories": {
      "output": "release"
    },
    "files": [
      "src/**",
      "package.json"
    ],
    "publish": {
      "provider": "github",
      "owner": "jizhoutang10thglobal",
      "repo": "wordspace-next"
    },
    "mac": {
      "target": [
        "dmg",
        "zip"
      ],
      "category": "public.app-category.productivity",
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "entitlements": "build-resources/entitlements.mac.plist",
      "entitlementsInherit": "build-resources/entitlements.mac.plist",
      "notarize": true,
      "artifactName": "wordspace-next-mac-${arch}.${ext}",
      "fileAssociations": [
        {
          "ext": [
            "html",
            "htm"
          ],
          "name": "HTML Document",
          "role": "Editor"
        }
      ]
    },
    "dmg": {
      "title": "Wordspace Next",
      "sign": true
    },
    "win": {
      "target": [
        "nsis"
      ],
      "artifactName": "wordspace-next-win-${arch}.${ext}",
      "fileAssociations": [
        {
          "ext": [
            "html",
            "htm"
          ],
          "name": "HTML Document",
          "role": "Editor"
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    },
    "afterAllArtifactBuild": "scripts/notarize-dmg.js"
  }
}
